    <msl:mapping id="_LumIICRHEfCFmaRZChN5Yg">
      <msl:annotations key="msl_mapping_documentation" value="ALS Status = Aanvraag EN er bestaat een Voorschotrecord met BDR _BT > 0 DAN code = 7&#xD;&#xA;ALS Status = Aanvraag EN er bestaat geen Voorschotrecord met BDR_BT > 0 DAN code = 88&#xD;&#xA;ALS Ind Afgewezen = 1  DAN code = 88&#xD;&#xA;ANDERS bepaal Peildatum:&#xD;&#xA;&#x9;ALS Toekenning &#x9;DAN 1e WW Dag&#xD;&#xA;&#x9;ALS Herleving/Heropening&#x9;&#x9;DAN datum-einde-laatste-uitkering ALS leeg, dan snapshot-datum&#xD;&#xA;&#x9;ALS Lopend &#x9;&#x9;&#x9;DAN datum-einde-laatste-uitkering ALS leeg, dan snapshot-datum&#xD;&#xA;&#x9;ALS Beéindigd&#x9;&#x9;DAN datum-einde-sessie, indien leeg cd 88 (er is geen uitkering gedaan)&#xD;&#xA;&#x9;ALS Oud Geval&#x9;&#x9;DAN datum-einde-sessie, indien leeg cd 88 (er is geen uitjering gedaan)&#xD;&#xA;&#x9;BEPAAL CODE:&#xD;&#xA;&#x9;&#x9;ALS Peildatum &lt;= Max Datum Basis 75   EN Ind Wn Overheid = 0, DAN code = 24 (fonds AWF)&#xD;&#xA;&#x9;&#x9;ALS Peildatum &lt;= Max Datum Basis 75   EN Ind Wn Overheid = 1, DAN code = 40 (fonds UFO)&#xD;&#xA;&#x9;&#x9;ALS Max Datum Basis 75 &lt; Peildatum &lt;= Max Datum Basis EN Ind Wn Overheid = 0, DAN code = 25 (fonds AWF)&#xD;&#xA;&#x9;&#x9;ALS Max Datum Basis 75 &lt; Peildatum &lt;= Max Datum Basis EN Ind Wn Overheid = 1, DAN code = 41 (fonds UFO)&#xD;&#xA;[ fases Verlengd, 26 en Vervolg, 27 komen niet meer voor]&#xD;&#xA;OPM: oorspronkelijk werd NR GAK OPDR = 42 voor de bepaling UFO gebruikt &#xD;&#xA;"/>
      <msl:input name="_path162" path="$_resource0/BDR WW Recht FT/DIM Fondscode Id" pathXmiId="_aH_04NonEe6lhuxCiAxxuw"/>
      <msl:output name="_path163" path="$_resource1/BDR WW Rapportage FT/DIM Fondscode Id" pathXmiId="_d7ftsCHnEfCUip_-JUXqIA"/>
